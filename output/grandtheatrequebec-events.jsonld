    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/tire-le-coyote-et-ses-amies/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Tire le coyote s’entoure de Salomé Leclerc, Antoine Corriveau et Safia Nolin pour rendre hommage à Leonard Cohen en français. Ensemble, ils interprètent une quinzaine de chansons, mises en mots par Tire le coyote, dans un spectacle qui célèbre l’homme et l’œuvre de cet artiste immense. Un événement rare et intime qui permet de redécouvrir autrement la spiritualité et la profondeur de ce répertoire incontournable.Pour chaque billet, 1,15 $ sera remis à la Fondation Cowboys FringantsBenoit Pinette remercie le CALQ pour le soutien et Mauricie Arts Vivants/le Théâtre des Lacs pour la résidence de création.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Tire le coyote et ses ami.es chantent Cohen... en français"
      }
    ],
