  {
    "@id": "https://grandtheatre.qc.ca/programmation/lynda-lemay-onzieme-folie/lynda-lemay-onzieme-folie-2026-05-31-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-05-31T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-LyndaLemaySebastien-St-Jean.jpg"
      }
    ],
