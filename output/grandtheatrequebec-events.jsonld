      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/constantinople-voix-laube/constantinople-voix-laube"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-12T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/constantinople-voix-laube/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/constantinople-voix-laube/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour cette nouvelle création de Constantinople, Kiya Tabassian et la chanteuse Maliheh Moradi nous entraînent dans un dialogue exceptionnel au cœur de la riche civilisation iranienne. Figure marquante de la nouvelle génération artistique, Maliheh Moradi a quitté l’Iran il y a quelques années pour poursuivre librement son parcours artistique. Héritière d’une tradition vocale parmi les plus raffinées au monde, elle déploie une voix d’une grande beauté, d’une profonde intensité et d’une maîtrise remarquable. Elle s’impose aujourd’hui comme l’une des voix féminines les plus prometteuses de la scène iranienne.La voix de l’aube révèle la richesse, la poésie et la sophistication d’un art musical façonné au fil des siècles et met en lumière les trésors de la musique persane et les créations de Kiya Tabassian. Plus qu’un concert, cette rencontre célèbre la liberté créatrice, la transmission et la résilience. Elle révèle la place essentielle de la voix féminine dans la culture iranienne contemporaine et rappelle la force de l’art lorsqu’il devient espace d’expression, de mémoire et d’espoir.Un voyage musical d’une grande intensité, porté par l’une des plus belles voix de l’Iran d’aujourd’hui.Une coprésentation de Constantinople et du Grand Théâtre de QuébecConsulter les autres concerts de la série Musique du mondeDistribution:Kiya Tabassian : séter &amp; chantMaliheh Moradi : chantHamin Honari : tombak"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Kiya Tabassian et Maliheh Moradi"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
