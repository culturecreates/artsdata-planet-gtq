  {
    "@id": "https://grandtheatre.qc.ca/programmation/un-dernier-tour-de-piste/un-dernier-tour-de-piste-2026-04-18-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-18T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428-x-599-QWARTZ.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g726600"
      }
    ],
    "http://schema.org/offers": [
      {
