    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/ferland-symphonique/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/ferland-symphonique/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans le cadre de la Série Prestige &amp; Patrimoine, GSI Musique et Oziko présentent Ferland symphonique; un hommage grandiose et vibrant créé sur l’œuvre du Petit Roi, l’unique Jean-Pierre Ferland. Cette grande aventure musicale prendra vie grâce aux arrangements symphoniques de Blair Thomson et sera interprétée par l’Orchestre symphonique de Québec, sous la direction du chef Alain Trudel. Des éléments de scénographie et de mise en scène seront annoncés sous peu… et à l’image de l’artiste qu’il était, ce sera rempli de poésie.Grand poète et bâtisseur, Jean-Pierre Ferland aura tissé des ponts entre la chanson à texte et la culture populaire, d’où l’importance de célébrer son héritage exceptionnel.Une présentation de GSI Musique et Oziko"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Avec l’Orchestre symphonique de Québec"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599_Ferland_symphonique_osq.jpg",
