  {
    "@id": "https://grandtheatre.qc.ca/programmation/tire-le-coyote-et-ses-amies/tire-le-coyote-et-ses-amies-2027-01-08-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-01-08T05:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
