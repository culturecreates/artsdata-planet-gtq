      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-25T01:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/bernard-werber/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/bernard-werber/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Il y a des spectacles qui divertissent et d’autres qui ouvrent des portes! Le spectacle V.I.E. (pour Voyage Intérieur Expérimental) est une expérience d’un nouveau genre. Dans ce mélange de rêve éveillé, de méditation guidée, d’humour et de musique relaxante, l’écrivain Bernard Werber vous invite à pratiquer du « tourisme spirituel ».Guidés par sa voix, par des chants oniriques et par la musique planante de la harpiste qui l’accompagne, vous vivrez une plongée dans votre propre imaginaire lors de cinq méditations guidées.C’est un moment étonnant où le célèbre auteur des Fourmis, de la Prophétie des Abeilles et des Thanatonautes vous propose en tant que conteur d’ouvrir des portes qui vous mèneront à la rencontre de vous-mêmes. Plus qu’un simple divertissement, c’est un moment rare où le théâtre se transforme en un lieu interactif d’où vous ressortirez transformé. Êtes-vous prêts à tenter l’expérience?Une présentation de Didier Morissonneau"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "V.I.E - Voyage Intérieur Expérimental"
      }
    ],
