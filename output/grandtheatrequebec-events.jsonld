    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/luc-larochelliere/luc-larochelliere"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-02T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/luc-larochelliere/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/luc-larochelliere/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour célébrer le 40e anniversaire de sa carrière, Luc De Larochellière présentera un spectacle spécialement conçu pour l’occasion. Le spectacle Paroles pour cordes sensibles, originalement offert en duo avec le guitariste Sylvain Quesnel, sera bonifié par la présence de François Lafontaine aux claviers, Blanche Baillargeon à la basse, Marie-Anne Tessier à la batterie et Étienne Ratthé aux percussions, au violoncelle et à la direction musicale.Pour ce concert exceptionnel au Grand Théâtre, plusieurs invités spéciaux se joindront à eux : Damien Robitaille, Tire le coyote, Marie-Pierre Arthur, Jordan Officer, Andrea Lindsay, Sylvie Paquette et Émilie Clepper.Entouré de ces artistes formidables, Luc De Larochellière offrira une relecture de ses classiques parmi lesquels Amère America, Si fragile, Cash City, Un toi dans ma tête, Sauvez mon âme ainsi que d’autres chansons de son vaste répertoire choisies avec soin pour cette célébration.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "40 ans de chansons avec invités spéciaux"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
