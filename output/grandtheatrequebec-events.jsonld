      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/constantinople-aux-racines-monde/constantinople-aux-racines-monde"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-06-14T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/constantinople-aux-racines-monde/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/constantinople-aux-racines-monde/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Inspiré des expressions musicales les plus anciennes, le concert Aux racines du monde réunit des artistes invités de Corée, des Premières Nations du Canada et d’autres horizons pour célébrer le 25e anniversaire de Constantinople.Les chants, rythmes et traditions transmis de génération en génération révèlent les liens profonds qui unissent les cultures. Des pratiques chamaniques aux grandes traditions musicales d’Asie, du Moyen-Orient et des Amériques, les artistes font émerger des résonances qui traversent les peuples depuis la nuit des temps. Entre héritage et création, mémoire et imaginaire, cette rencontre réunit des voix exceptionnelles dans une ode à l’humanité, où la musique est un langage commun. Une grande fête des cultures vivantes vient ainsi marquer vingt-cinq années de dialogue, de découvertes et de rencontres portées par Constantinople.Une coprésentation de Constantinople et du Grand Théâtre de QuébecConsulter les autres concerts de la série Musique du mondeDistribution:Kiya Tabassian : sétar &amp; chantDidem Basar : kanunKianoush Khalialian : neyPatrick Graham : percussionHamin Honari : tombak &amp; daf&amp; musiciens invités"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Avec musiciens invités"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
