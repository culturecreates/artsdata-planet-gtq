    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/JPR_MISERABLES_008_Visuel_moteur_MEV_numerique_SALLE_GT_Qc_428x600.png"
      }
    ],
