  {
    "@id": "https://grandtheatre.qc.ca/programmation/michel-rivard/michel-rivard-2027-05-21-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-05-21T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599_MichelRivardMarcEtienneMongrain.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/880dccbbdcfc06ed"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/2e69dfa2a3d3561e"
      }
    ],
    "http://schema.org/organizer": [
      {
