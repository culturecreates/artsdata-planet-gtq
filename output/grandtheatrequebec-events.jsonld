      {
        "@id": "https://grandtheatre.qc.ca/programmation/emile-proulx-cloutier-solo/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Après trois albums aux textes éloquents accentués d’une richesse musicale saluée par le public et la critique, Émile Proulx-Cloutier nous éblouit une fois de plus avec sa voix percutante, assumée et émouvante, confirmant qu’il a su définir le son d’un univers musical bien à lui. Dans ce spectacle, l’auteur-compositeur-interprète nous livre en solo les nouvelles chansons de son album Ma main au feu, ainsi que plusieurs autres pièces poétiques et vives de son répertoire.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ma main au feu - Solo"
      }
    ],
