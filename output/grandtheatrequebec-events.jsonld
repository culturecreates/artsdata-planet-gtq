  {
    "@id": "https://grandtheatre.qc.ca/programmation/nicolas-noel-entre-deux-mondes/nicolas-noel-entre-deux-mondes-2026-12-19-20-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
