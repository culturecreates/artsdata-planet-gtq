  {
    "@id": "https://grandtheatre.qc.ca/programmation/avec-luce-dufault-lulu-hughes-et-kim-richardson/avec-luce-dufault-lulu-hughes-et-kim-richardson-2026-04-12-23-00",
    "@type": [
      "http://schema.org/Event"
    ],
