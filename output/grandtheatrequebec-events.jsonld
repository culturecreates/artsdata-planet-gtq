        "@id": "https://grandtheatre.qc.ca/programmation/un-tramway-nomme-desire-trident/le-theatre-du-trident"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/un-tramway-nomme-desire-trident/un-tramway-nomme-desir"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
