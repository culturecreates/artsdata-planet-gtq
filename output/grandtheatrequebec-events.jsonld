  {
    "@id": "https://grandtheatre.qc.ca/programmation/remi-cormier/remi-cormier-2026-06-28-15-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
