  },
  {
    "@id": "https://grandtheatre.qc.ca/programmation/albanie/albanie-2027-04-18-18-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-18T22:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/LGE_2627_Albanie_428x599.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/7defda9f9477a149"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/8f8abbc396043fb0"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/98d3adafb2bed0b6"
      }
    ],
    "http://schema.org/organizer": [
      {
