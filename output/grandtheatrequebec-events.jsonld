  {
    "@id": "https://grandtheatre.qc.ca/programmation/laura-calu-senk/laura-calu-senk-2027-03-31-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-31T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Laura-Calu-idrnz.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2947760"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2947840"
