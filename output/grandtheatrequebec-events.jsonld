    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/emile-londonien-inwards/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Emile Londonien présente sur scène les pièces de son plus récent projet, Inwards. Ce deuxième album marque la croissance et le développement du groupe en faisant des clins d’œil à la scène jazz britannique et à des artistes confirmés comme Ashley Henry, CHERISE et Kazy Lambist. Les musiciens du groupe continuent également de se positionner comme des têtes de proue de la nouvelle scène jazz française en invitant des artistes prestigieux tels que Laurent Bardainne, Jowee Omicil et Léon Phal à participer à l’album. Une fois de plus, Emile Londonien surprend par sa capacité à mélanger des sonorités house, broken beat, jazz et R&amp;B d’une manière très singulière.Ce spectacle est une coprésentation du Grand Théâtre de Québec et du Festival Québec Jazz en Juin"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Inwards"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
