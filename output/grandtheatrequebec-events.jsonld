  {
    "@id": "https://grandtheatre.qc.ca/programmation/bernard-werber/bernard-werber-2026-11-25-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
