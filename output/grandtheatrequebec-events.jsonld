    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/hubert-proulx-on-slache-pas/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans le spectacle On s’lâche pas, le comédien, musicien et auteur Hubert Proulx raconte l'histoire des Proulx, une famille tissée serrée. Il partage la relation qu’il entretient avec son frère toxicomane, Steeven. Avec transparence et authenticité, il livre cette histoire, son histoire, accompagné de son fils Viktor.Mis en scène par Anne Dorval avec la complicité de Vincent Bolduc à la script-édition, On s’lâche pas est un récit captivant, drôle et touchant qui aborde les modèles et la transmission avec beaucoup d’humanité.Une présentation du Grand Théâtre de Québec\n"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "On s’lâche pas"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
