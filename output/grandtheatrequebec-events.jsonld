  {
    "@id": "https://grandtheatre.qc.ca/programmation/half-moon-run-filmharmonique/",
    "http://ogp.me/ns#url": [
      {
        "@language": "fr",
        "@value": "/programmation/half-moon-run-filmharmonique/"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Half Moon Run & l'Orchestre FILMharmonique"
      }
    ],
    "http://ogp.me/ns#description": [
