  {
    "@id": "https://grandtheatre.qc.ca/programmation/dancers-of-damelahamid/dancers-of-damelahamid-2026-06-10-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-06-10T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-RavenMotherMichaelSlobodian.jpg"
      }
    ],
    "http://schema.org/location": [
