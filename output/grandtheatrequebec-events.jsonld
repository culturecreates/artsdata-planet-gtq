  {
    "@id": "https://grandtheatre.qc.ca/programmation/arthur-laventurier-symphonique/arthur-laventurier-symphonique-2027-03-21-18-30",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-21T22:30:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/20270321_-_Arthur_laventurier_Arthur_afrique_428x599.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g3088960"
      }
    ],
    "http://schema.org/offers": [
