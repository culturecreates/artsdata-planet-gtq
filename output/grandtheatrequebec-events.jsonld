      {
        "@id": "https://grandtheatre.qc.ca/programmation/rosalie-brulotte/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Ce concert se veut une opportunité d’entendre le programme de demi-finale que la soprano Rosalie Brulotte fera lors de son passage au concours Prix d’Europe. À la même occasion, ce sera pour elle une manière de faire un rodage sur son répertoire et de s’y mettre à son aise, question de briller de mille feux à Montréal le 9 juin prochain ! Vous aurez la chance d’y entendre du Gluck, Händel, Poulenc, Offenbach, Massenet, Wagner ainsi que du Gagnon, un compositeur et collègue du Conservatoire de musique de Québec. Rosalie sera accompagnée au piano par la fabuleuse Anne-Marie Bernard!"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "En route vers le Prix d’Europe"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
