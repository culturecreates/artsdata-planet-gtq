  {
    "@id": "https://grandtheatre.qc.ca/programmation/les-charbonniers-de-l-enfer/les-charbonniers-de-l-enfer-2026-12-06-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
