  {
    "@id": "https://grandtheatre.qc.ca/programmation/luc-larochelliere/luc-larochelliere-2027-04-02-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-02T04:00:00+00:00"
      }
    ],
