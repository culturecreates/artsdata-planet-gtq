      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fort du succès de sa première édition, One More Time – Hommage électro-symphonique à Daft Punk s’impose comme un rendez-vous incontournable.Le spectacle propose une expérience musicale à la croisée de la musique électronique et du symphonique, où les œuvres du mythique duo français sont revisitées dans une relecture orchestrale saisissante.Porté par l’artiste québécois Barnev et les musiciens de l’Orchestre FILMharmonique, sous la direction de Francis Choinière, le concert combine puissance orchestrale, énergie électronique et mise en lumière pour une soirée intense et vibrante.Interprétation : BarnevChef d’orchestre : Francis ChoinièreOrchestre FILMharmoniquePrésenté par Les Agents Doubles Productions"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "One More Time"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
