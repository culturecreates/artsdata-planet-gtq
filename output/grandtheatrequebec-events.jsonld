    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/dumas-piano-voix-diapos/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans ce nouveau spectacle, le public retrouvera Dumas sans sa guitare, accompagné plutôt d’un pianiste et de diapositives. Évoluant dans une mise en scène minimaliste, il se racontera en chansons et revisitera 25 ans de répertoire avec une sensibilité touchante et une volonté profonde d’offrir une expérience inoubliable et lumineuse.1,15 $ sera remis à la Fondation Cowboys FringantsUne présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "PIANO VOIX DIAPOS"
      }
    ],
