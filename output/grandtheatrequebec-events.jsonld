    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/croissants-musique-pako/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/croissants-musique-pako/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Présentés en collaboration avec le Festival KWE! À la rencontre des peuples autochtones, le public pourra profiter d’un réjouissant « Bannique-Musique » (alternative à nos traditionnels Croissants-Musique) spécialement orchestré pour l’occasion en compagnie de l’artiste Pako. Cet auteur-compositeur-interprète originaire de la communauté atikamekw de Manawan interprète les textes qu’il écrit dans sa langue natale, l’atikamekw, sur un folk-rock solide et maîtrisé. Il aborde des thèmes qui lui sont tels que l’importance de la langue, les valeurs et l’histoire de sa communauté, l’identité, l'environnement, les relations humaines et l’espoir d’une vie meilleure.Une coprésentation du Grand Théâtre de Québec et du Festival KWE! À la rencontre des peuples autocthonesLes Croissants-Musique sont des spectacles gratuits présentés certains dimanches matin dans le foyer de la salle Louis-Fréchette, où café et viennoiseries vous sont offerts. Si vous aimez découvrir des artistes, consultez les autres événements de cette série!"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Croissants-Musique"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
