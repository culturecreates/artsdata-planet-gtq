      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/remi-cormier/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/remi-cormier/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Fusionnant le jazz, l’énergie du hip-hop, des textures électroniques et une créativité sans limites, ce projet résolument moderne du trompettiste canadien Rémi Cormier est inspiré par des artistes comme Robert Glasper et Roy Hargrove. Sur scène, l’ensemble livre des performances explosives, dynamiques et imprévisibles — parfois brutes, parfois téméraires, mais toujours profondément musicales.Le cœur du répertoire est composé de quelques pièces du premier album Glimpse mais surtout d’œuvres du récent album Rich State of Mind, qui se veut une réflexion sur les formes de richesse non matérielles : la créativité, les connexions humaines et la résilience. Les spectateurs de ce concert présenté dans le cadre des Croissants-Musique auront droit à du jazz contemporain en mouvement constant — une fusion de beats, de cuivres et d’idées fortes, conçu pour faire vibrer à la fois les esprits et les corps.Une coprésentation du Grand Théâtre de Québec et du Festival Québec Jazz en JuinLes Croissants-Musique sont des spectacles gratuits présentés certains dimanches matin dans le foyer de la salle Louis-Fréchette, où café et viennoiseries vous sont offerts. Si vous aimez découvrir des artistes, consultez les autres événements de cette série!"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Croissants-Musique"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
