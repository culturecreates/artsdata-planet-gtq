    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/jourdan-thibodeaux-et-les-rodailleurs-oc/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Jourdan Thibodeaux est l’incarnation du mot « authentique ». Tout droit venu des bois marécageux de Cypress Island, en Louisiane, il est l’un des rares jeunes à parler couramment le cajun encore aujourd’hui. Son chant puissant et son violon accompagnent avec brio et sincérité son répertoire de chansons originales en français de Louisiane.Présenté notamment au Jazz Fest de la Nouvelle-Orléans à South by Southwest, à Austin, et au Congrès mondial acadien, l’ensemble Jourdan Thibodeaux et Les Rôdailleurs s’est forgé une réputation à travers les États-Unis en unissant les traditions anciennes et une énergie incomparable. Les Rôdailleurs sont, par ailleurs, les musiciens par excellence de la musique cajun (et nommés aux Grammys!) Joel Savoy, Cedric Watson, Alan Lafleur et Adam Cormier. Rencontrez-les et vibrez au son d’une musique cajun vraie et actuelle!Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Jourdan Thibodeaux & Les Rôdailleurs"
      }
    ],
