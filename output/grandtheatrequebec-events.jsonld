      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/1500-85-trident-web-GTQ-428x599-3.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2529760"
      }
    ],
    "http://schema.org/offers": [
      {
