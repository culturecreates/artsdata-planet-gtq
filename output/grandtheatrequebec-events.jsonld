  {
    "@id": "https://grandtheatre.qc.ca/programmation/simon-boisseau-fausses-illusions/simon-boisseau-fausses-illusions-2027-05-28-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-05-28T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Simon-Boisseau-Credit-Jules-Bedard.png"
      }
    ],
    "http://schema.org/location": [
      {
