      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/539ae9e357e909ae"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/simon-boisseau-fausses-illusions/simon-boisseau"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-05-28T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/simon-boisseau-fausses-illusions/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/simon-boisseau-fausses-illusions/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour l’élaboration de son nouveau spectacle Les fausses illusions, Simon Boisseau puise dans l’une de ses passions : le cinéma d’animation. Alternant entre pièces pour piano solo et morceaux appuyés par une violoncelliste, il présente des œuvres issues de ses deux albums lesquelles sont magnifiées par les jeux d’éclairage d’Anthony Piazza et les saynètes en stop-motion réalisées par Laura Venditti. Dans celles-ci, on suit un personnage reflétant l’enfance et l’apprentissage du musicien, relatant sa quête de développement personnel et d’acceptation de soi.Tout au long de ce concert enveloppant et ludique, Simon Boisseau navigue entre humour et mélancolie, autodérision et sensibilité, offrant au public l’opportunité de se reconnaître dans ses histoires. Son jeu de piano impressionniste traduit des émotions révélant une trame sonore riche, parsemée de thèmes récurrents et de détours surprenants. Notons qu’en dehors de sa pratique de soliste, Simon accompagne également Fredz et Émile Bourgault, en plus d’être membre de la formation pop-rock-funk Barber For The Queen.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les fausses illusions"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
