    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/charles-beauchesne-jack-eventreur/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "DERNIÈRES SUPPLÉMENTAIRESLondres, à la fin du 19e siècle. Alors que la populace trime matin et soir dans les usines toxiques et dangereuses de l’ère industrielle, un monstre sans nom ni visage se terre dans les ruelles. On lui attribue l’assassinat de prostitués que l’on retrouvait la gorge tranchée et les organes reproducteurs atrocement mutilés dans les rues de Whitechapel. À ce jour, ces meurtres n’ont toujours pas été résolus et l’homme derrière ces crimes sanglants demeure un mystère.Féru d’histoire, le sinistre humoriste Charles Beauchesne part sur les traces de Jack l’éventreur et tente (tout en humour, doit-on le rappeler) de percer le secret du plus légendaire des tueurs en série.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "parle de Jack l'Éventreur - Dernières Supplémentaires"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
