    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/2freres-symphonique-osq/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Connus pour leurs textes sincères et leur engagement envers la société québécoise, 2Frères donnent une nouvelle couleur à leurs chansons avec une fusion parfaite entre la puissance de l’Orchestre et la sensibilité des mélodies. Entre folk, rock et influences de musique traditionnelle, leur répertoire prend une ampleur inédite dans ces arrangements orchestraux spécialement conçus pour l’occasion.Redécouvrez leurs plus grands succès — de Nous autres à Sous le même toit — ainsi que des pièces de leur dernier album Science humaine, où chaque chanson résonne avec les valeurs du Québec, apportant une profondeur et une dimension particulière à leurs airs rassembleurs. Une soirée sous le signe de la solidarité, de l’émotion et du partage!Une présentation de l'Orchestre symphonique de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Orchestre symphonique de Québec"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
