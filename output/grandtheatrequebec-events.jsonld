  {
    "@id": "https://grandtheatre.qc.ca/programmation/quest-ce-quon-a-fait-au-bon-dieu/quest-ce-quon-a-fait-au-bon-dieu-2026-11-14-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
