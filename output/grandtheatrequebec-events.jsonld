  {
    "@id": "https://grandtheatre.qc.ca/programmation/etienne-coppee/etienne-coppee-2026-10-16-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
