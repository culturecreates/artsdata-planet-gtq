  {
    "@id": "https://grandtheatre.qc.ca/programmation/constantinople-voix-laube/constantinople-voix-laube-2027-04-12-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-04-12T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Voix_de_laubeJulia_Marois_3.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/7838708f34be0937"
      },
      {
