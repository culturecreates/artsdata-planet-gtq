      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-VTAL-Credit-Sylvie-Ann-Pare-Interpretes-Laura-Perron-Erismel-Mejia.jpg"
      }
    ],
