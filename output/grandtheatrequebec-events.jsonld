      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/93abbe720a7253a0"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/9e7ab821a7e0db9d"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/a7735b349121b885"
      },
      {
        "@id": "https://grandtheatre.qc.ca/genid/0d6cfc1840b68b40"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/7-minutes-comite-usine-trident/le-theatre-du-trident"
