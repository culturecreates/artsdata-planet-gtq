      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
  {
    "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Laura-Calu-idrnz.png",
    "@type": [
      "http://schema.org/ImageObject"
    ],
    "http://schema.org/contentUrl": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Laura-Calu-idrnz.png"
      }
    ],
