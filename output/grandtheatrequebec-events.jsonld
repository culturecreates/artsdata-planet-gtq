  {
    "@id": "https://grandtheatre.qc.ca/programmation/marie-pierre-arthur-ensemble-doux/marie-pierre-arthur-ensemble-doux-2026-12-04-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
