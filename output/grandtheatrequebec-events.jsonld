    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/sue-foley/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Nommée aux GRAMMY®, la guitariste et chanteuse blues canadienne Sue Foley et son groupe livrent un blues texan énergique et flamboyant. Celle qui possède une voix redoutable et un charisme irrésistible vibre sur scène avec autant d’aisance que de fougue.Une présentation de District 7 Productions« Et quelle énergie !... Un groove savoureux, tout droit venu des tripes et du cœur. Continuez à rocker ! » — Billy Gibbons, ZZ Top« Sue Foley a une façon bien à elle de faire exploser le blues depuis la scène. » — Americana Highways"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Sue Foley"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
