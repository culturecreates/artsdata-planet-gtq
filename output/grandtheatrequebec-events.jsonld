  {
    "@id": "https://grandtheatre.qc.ca/programmation/cendrillon/cendrillon-2027-03-10-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-10T05:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
