        "@value": "Francine Ruel - La Colombe, le pigeon et moi"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Soyez des nôtres pour « La Colombe, le pigeon et moi » de Francine Ruel au Grand Théâtre. Billets en vente maintenant!"
      }
    ],
