  {
    "@id": "https://grandtheatre.qc.ca/programmation/yves-lambert-50-ans-bottine-aujourd-hui/yves-lambert-50-ans-bottine-aujourd-hui-2026-12-13-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
