    "http://ogp.me/ns#title": [
      {
        "@language": "fr",
        "@value": "Catherine Dorion - Sciences po 101"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "fr",
        "@value": "Retrouvez Catherine Dorion dans un projet théâtral hors-norme sur les planches du Grand Théâtre de Québec en février 2025. Réservez vite vos places!"
