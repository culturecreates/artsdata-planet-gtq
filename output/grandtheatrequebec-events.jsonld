    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/nicolas-noel-entre-deux-mondes/nicolas-noel"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-19T20:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/nicolas-noel-entre-deux-mondes/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le Père Nicolas Noël vous invite à vivre un tout nouveau spectacle musical festif en compagnie de ses fidèles lutins Pamalin et Trémaline. Cette fois, la jeune lutine fraîchement diplômée de l’École des Lutins arrive avec une idée des plus déroutantes : moderniser Noël! Elle ne fait pas les choses à moitié : Adieu les rennes et la grande distribution en traineau et vive les drones de livraison! Fini les rencontres chaleureuses avec le Père Noël et bonjour les appels virtuels et la réalité augmentée!La magie de Noël sera-t-elle effacée pour faire place à l’intelligence artificielle?!Tiraillé entre le respect des traditions et le besoin de s’adapter aux nouvelles technologies, le grand homme à la barbe blanche devra user de sa sagesse pour sauver la Grande Nuit Magique… Une occasion de célébrer, tous ensemble, une fête merveilleuse : Noël!Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Entre deux mondes"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
