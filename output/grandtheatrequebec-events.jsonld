        "@id": "https://grandtheatre.qc.ca/programmation/albert-asselin/albert-asselin"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-04-14T22:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/albert-asselin/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/albert-asselin/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "FORMULE 6 À 8Début des prestations autour de 18 h 30 À l’occasion de la sortie de son premier mini-album (EP) Prémices, Albert Asselin vous invite à découvrir son univers musical.Révélé au grand public lors de Star Académie 2025 où il a atteint la demi-finale, l’auteur-compositeur-interprète se dévoile à travers six chansons où paroles, musique, voix et arrangements ont été soigneusement réfléchis.Entouré de musiciens, il propose un spectacle aux atmosphères contrastées, allant de chansons plus douces à des titres plus rythmés, où ses compositions prennent toute leur ampleur.Laissez-vous surprendre par ce jeune artiste de Québec."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Prémices - Lancement de EP"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
