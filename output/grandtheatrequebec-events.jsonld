    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/pat-metheny-side-eye-iii/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le guitariste et compositeur Pat Metheny, lauréat de 20 Grammy Awards, revient avec Side-Eye III+, son plus grand ensemble depuis plus de dix ans, où il sera accompagné de Joe Dyson (batterie), Chris Fishman (claviers), Jermaine Paul (basse) et Leonard Patton (percussions et chant). S’appuyant sur l’album Side-Eye III+, le spectacle propose de nouvelles compositions ambitieuses ainsi que des réinterprétations audacieuses de ses morceaux préférés et de classiques de son répertoire. Il en résulte une performance puissante et novatrice qui met en lumière l’évolution constante de Metheny tout en rendant hommage au son qui a marqué sa carrière légendaire.Une présentation de Modo-Live"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Side-Eye III+"
      }
    ],
