      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "À l'occasion de la parution de son nouvel album à paraître durant l'automne, Sara Dufour annonce du même coup qu'elle repartira en tournée partout au Québec en 2027. Entourée de ses musiciens, elle proposera un spectacle où se mêleront ses nouvelles chansons et ses succès incontournables, le tout porté avec authenticité et partagé avec son énergie contagieuse et sa proximité unique avec le public.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Nouveau spectacle"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
