  {
    "@id": "https://grandtheatre.qc.ca/programmation/simon-boisseau/simon-boisseau-2026-05-10-15-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
