      {
        "@id": "https://grandtheatre.qc.ca/programmation/zza/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "zza est un trio de musique instrumentale de la ville de Québec. Le groupe combine la spontanéité, l’improvisation et l’interaction du jazz avec une perspective de production actuelle. La formation assure les enregistrements et la production de son matériel depuis son local au Pantoum. Le groupe présentera ses nouvelles compositions marquées par les sonorités électroniques et hip-hop de la scène londonienne et allemande.Une coprésentation du Grand Théâtre de Québec et du Festival Québec Jazz en Juin en collaboration avec Desjardins "
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "zza"
      }
    ],
