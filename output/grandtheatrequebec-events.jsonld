    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/star-wars-l-empire-contre-attaque-en-concert/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Joignez-vous à l’Orchestre FILMharmonique pour un autre voyage dans une galaxie lointaine, très lointaine avec le ciné-concert Star Wars : L’Empire contre-attaque. La partition emblématique du compositeur oscarisé John Williams sera interprétée en direct par les 70 musiciens de l'Orchestre FILMharmonique sous la direction de Francis Choinière, tandis que le film remastérisé de 1980 sera projeté sur grand écran! Créé par George Lucas et réalisé par Irvin Kirshner, ce cinquième épisode est peut-être la plus grande réussite de la saga Star Wars. Découvrez la puissance de la force, en concert!Une présentation de l’Orchestre FILMharmonique et des Productions GFN© 1980 &amp; TM LUCASFILM LTD. ALL RIGHTS RESERVED. Presentation licensed by Disney Concerts in association with 20th Century Fox, Lucasfilm Ltd.,and Warner/Chappell Music"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "STAR WARS : L'Empire contre-attaque - En concert"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
