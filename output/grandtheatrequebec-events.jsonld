      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-14T00:30:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/tocadeo-noel-blanc/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/tocadeo-noel-blanc/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Le célèbre ensemble vocal Tocadéo vous invite à célébrer le temps des Fêtes avec le spectacle Noël blanc de retour en supplémentaire. Dans une mise en scène qui s’appuie sur un concept et un décor de circonstance, Benoit, Dany, Patrick et René revisitent, à leur façon, les grands classiques de Noël dans une ambiance festive et nostalgique qui vous fera revivre l’époque des réveillons d’antan.Depuis 15 ans, le spectacle de Noël de Tocadéo s’est imposé comme un événement annuel incontournable et une véritable tradition des Fêtes. Laissez-vous emporter, bercer et émouvoir par le talent exceptionnel et les magnifiques voix du sympathique quatuor!Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Noël blanc"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
