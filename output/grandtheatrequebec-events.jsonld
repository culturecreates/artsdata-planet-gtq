  {
    "@id": "https://grandtheatre.qc.ca/programmation/7-minutes-comite-usine-trident/7-minutes-comite-usine-trident-2027-02-06-21-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-02-07T01:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/1500-85-trident-web-GTQ-428x599-3.png"
      }
    ],
    "http://schema.org/location": [
      {
