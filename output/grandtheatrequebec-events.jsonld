    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/simon-leblanc-present/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Simon Leblanc a plus envie que jamais de sillonner le Québec en quête de paysages et de faces qui rient. Simon repart donc en tournée pour présenter son quatrième spectacle, Présent. Il a hâte de vous voir comme ça s'peut pas! À bientôt tout le monde…Une présentation de Groupe PhaneufImportant! Pour contrer la revente illégale et protéger notre clientèle, aucun billet PDF ne sera émis pour ce spectacle.Seuls les billets ajoutés au portefeuille virtuel, ceux disponibles dans votre compte client et les billets imprimés par la billetterie du Grand Théâtre seront honorés sur place.Les codes à barres seront activés 48 h avant l’événement, sont rotatifs et mis à jour aux quelques secondes. L’option transfert est désactivée. Nous vous remercions de votre compréhension!Vous n'êtes pas familier avec les billets électroniques? Consultez cette page pour découvrir en images les quelques étapes simples à suivre."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Présent"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
