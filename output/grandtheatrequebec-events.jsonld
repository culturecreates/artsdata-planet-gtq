    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/louis-jean-cormier-symphonique/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Depuis plus de vingt ans, Louis-Jean Cormier explore l’intime avec une sensibilité qui a marqué le paysage musical québécois. Son univers poétique prend une nouvelle dimension lors d’un concert symphonique exceptionnel aux côtés de l’Orchestre FILMharmonique. L’auteur-compositeur-interprète revisite les chansons les plus marquantes de son répertoire avec des arrangements orchestraux inédits signés Francis Choinière. Un mariage musical saisissant où chaque morceau gagne en profondeur et en émotion.Producteur / Diffuseur : GFN Productions et Orchestre FILMharmoniqueChef d’orchestre : Francis ChoinièreInterprété par : Louis-Jean Cormier et l’Orchestre FILMharmonique"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Louis-Jean Cormier et l'Orchestre FILMharmonique"
      }
    ],
