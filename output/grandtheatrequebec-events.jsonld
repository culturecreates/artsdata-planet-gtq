      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-22T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/coco-belliveau-cocologie/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/coco-belliveau-cocologie/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "En 1692 à Salem, des procès ont été mis en place afin de mettre fin à la sorcellerie. Des centaines d'années plus tard, Coco Belliveau fait le rodage de son prochain spectacle. Coïncidence ? Nous ne croyons pas…Joignez-vous à cette charmante acadienne neurodivergente (et totalement brûlée) pour une soirée d’anecdotes envoûtantes. Voyez-la vite avant qu'elle ne soit clouée au pilori pour ses calembredaines et sa Cocologie aiguisée!Une présentation du Grand Théâtre de QuébecLire la chronique : Dans la tête de Coco Belliveau"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Cocologie"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
