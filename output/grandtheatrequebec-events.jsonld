  {
    "@id": "https://grandtheatre.qc.ca/programmation/votre-voyage-extraordinaire/votre-voyage-extraordinaire-2026-11-15-19-30",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-11-15T23:30:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/15_novembre_VOTRE_VOYAGE_EXTRAORDINAIRE_Rachel_Bailargeon_428x599.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2118680"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2118760"
