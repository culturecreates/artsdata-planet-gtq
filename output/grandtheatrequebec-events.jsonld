    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/jf-pauze/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "JF Pauzé, membre des Cowboys Fringants et auteur-compositeur des chansons du groupe (Félix – Auteur-compositeur de l’année 2024), fait ses débuts en solo avec un premier album à titre d’interprète composé de 11 nouveaux titres originaux.JF remettra les pieds sur scène en 2026, entouré de musiciens, avec un spectacle généreux et festif qui comptera plus de 20 chansons, incluant plusieurs des Cowboys Fringants. Un moment important dans le paysage musical québécois pour les saisons à venir!1$ par billet vendu sera remis à la Fondation Cowboys Fringants.Merci 💚Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Les amours de seconde main"
      }
    ],
