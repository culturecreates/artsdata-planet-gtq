  {
    "@id": "https://grandtheatre.qc.ca/programmation/7-minutes-comite-usine-trident/7-minutes-comite-usine-trident-2027-02-03-00-30",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
