  {
    "@id": "https://grandtheatre.qc.ca/programmation/yves-lambert-50-ans-bottine-aujourd-hui/yves-lambert-50-ans-bottine-aujourd-hui-2026-12-13-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-13T05:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Yves-Lambert.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/4b667b24e897df1e"
