  {
    "@id": "https://grandtheatre.qc.ca/programmation/constantinople-aux-racines-monde/constantinople-aux-racines-monde-2027-06-14-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-06-14T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Kiya_TabassianJulia_Marois.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
    "http://schema.org/offers": [
