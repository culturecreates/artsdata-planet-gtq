  {
    "@id": "https://grandtheatre.qc.ca/programmation/marie-pierre-arthur-ensemble-doux/marie-pierre-arthur-ensemble-doux-2026-12-04-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-04T05:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Marie-Pierre-Arthur---Credit---Camille-Gladu-Drouin.jpg"
      }
    ],
