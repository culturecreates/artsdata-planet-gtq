  {
    "@id": "https://grandtheatre.qc.ca/programmation/boulevard-perusse/boulevard-perusse-2027-05-01-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
