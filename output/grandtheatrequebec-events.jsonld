    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/thierry-du-sablon/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/thierry-du-sablon/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Bassiste électrique exaltant, Thierry Du Sablon souhaite rendre hommage à sa culture et au patrimoine québécois par le biais de sa musique. En commençant très jeune à écouter du rock progressif sur les genoux de son père, il a évolué dans un univers musical riche qui le pousse aujourd’hui à trouver de nouvelles avenues pour le jazz contemporain. En fusionnant sa musique jazz à des influences de musique québécoise comme le folk, le trad, la musique des chansonniers et le prog, il crée quelque chose d’unique en son genre qui lui permet de tirer son épingle du jeu.Son premier EP Live at Elspot dévoilait des compositions témoignant de ses différentes explorations musicales depuis ses débuts. Lancé au STUDIOTELUS dans le cadre du Festival Québec Jazz en Juin, son premier album Portraits de mon chez-moi révèle une recherche approfondie de la musique québécoise.En plus de créer ses propres compositions, Thierry a accompagné certains des meilleurs musiciens jazz du Québec et du Canada, tels que Rafael Zaldivar, Virginia MacDonald, Janis Steprans, Rémi Bolduc et François Rioux (Lost Fingers). En 2024, il a gradué d’un baccalauréat en interprétation jazz à l’Université Laval et a ensuite complété une maîtrise en interprétation au Berklee College of Music à Valence, en Espagne.Une coprésentation du Grand Théâtre de Québec et du Festival Québec Jazz en Juin"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Portraits de mon chez-moi - Lancement d'album"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
