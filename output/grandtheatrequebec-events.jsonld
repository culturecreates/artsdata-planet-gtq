      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/bingo-litteraire-kwahiatonhk/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans une ambiance festive et humoristique, nous vous invitons à venir découvrir la littérature des Premières Nations des années 1970 à aujourd’hui en jouant à un jeu de bingo bien spécial où le boulier décide quels textes du corpus littéraire autochtone liront les auteurs invités et les volontaires du public. À la charnière du spectacle littéraire et du jeu interactif, cette activité est animée par Louis-Karl Picard-Sioui et Andrée Levesque Sioui et soutenue par un musicien sur scène, Marc Vallée.En prime, assistez à la remise des Prix Voix autochtones 2026.Une coprésentation du Grand Théâtre de Québec et du festival KWE! À la rencontre des peuples autochtones"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Bingo littéraire Kwahiatonhk!"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
