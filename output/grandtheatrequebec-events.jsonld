  {
    "@id": "https://grandtheatre.qc.ca/programmation/lynda-lemay-onzieme-folie/lynda-lemay-onzieme-folie-2026-08-31-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
