  {
    "@id": "https://grandtheatre.qc.ca/programmation/jacques-kuba-seguin-concert-pour-toutes-oreilles/jacques-kuba-seguin-concert-pour-toutes-oreilles-2026-06-27-15-00",
    "@type": [
      "http://schema.org/Event"
    ],
