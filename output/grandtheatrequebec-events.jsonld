  {
    "@id": "https://grandtheatre.qc.ca/programmation/michel-rivard/michel-rivard-2027-05-22-00-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-05-22T04:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599_MichelRivardMarcEtienneMongrain.jpg"
      }
    ],
    "http://schema.org/location": [
      {
