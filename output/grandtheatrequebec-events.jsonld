    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/avec-luce-dufault-lulu-hughes-et-kim-richardson/elles"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
