  {
    "@id": "https://grandtheatre.qc.ca/programmation/maude-landry-trop-cool/maude-landry-trop-cool-2026-12-12-01-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-12T05:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/428x599-Maude-Landry.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g2386160"
      }
    ],
    "http://schema.org/offers": [
      {
        "@id": "_:g2386240"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g2386260"
      }
    ],
    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/maude-landry-trop-cool/maude-landry"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-12T01:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/maude-landry-trop-cool/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/maude-landry-trop-cool/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Dans un monde où il faut se démarquer tout en suivant les tendances, Maude Landry se demande pourquoi elle n’a jamais fait partie de la gang des cools. C’est ce qui la rend attachante. Décontractée et pince-sans-rire, elle pose son regard taquin sur elle-même et sur la société, en passant délibérément par quatre chemins. Un spectacle moderne et assumé, pendant lequel on se dit parfois « C’est niaiseux!... Mais fallait y penser ». Maude vous invite dans un périple au cœur de ses réflexions, ses doutes et ses déboires, pour que vous sortiez de la salle en disant « C’était trop cool! ».Une présentation de Encore Spectacle"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Trop cool"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
