  {
    "@id": "https://grandtheatre.qc.ca/programmation/ouzbekistan/ouzbekistan-2027-03-14-18-00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2027-03-14T22:00:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/LGE_2627_Ouzbekistan_428x599.jpg"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "https://grandtheatre.qc.ca/genid/f7b3d63b5ecd1116"
      }
    ],
