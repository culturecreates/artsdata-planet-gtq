    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/supertramp-memories-la-supplementaire/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": " Depuis 20 ans, le groupe School se commet dans des salles et festivals au Québec et au Canada avec son hommage Supertramp Memories. Reconnue pour son interprétation rigoureuse et énergique des plus grands succès de Supertramp, la formation originaire de la Mauricie a notamment fait sensation à l’Amphithéâtre Cogeco de Trois-Rivières et au Grand Théâtre de Québec où elle est de retour en supplémentaire!Porté par des musiciens aguerris qui ont fait leurs preuves aux côtés d’artistes notoires tels que Céline Dion, Sylvain Cossette, Lynda Lemay, Luce Dufault ou Marie-Mai, par exemple, School offre un concert chaleureux, théâtralisé et relevé qui permet d’apprécier l’imposant répertoire du groupe rock britannique issu des années 70. Une expérience mémorable qui ravira les nostalgiques! Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "School"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
