    "http://schema.org/performer": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/etienne-coppee/show-dassin"
      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-10-17T00:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/etienne-coppee/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/etienne-coppee/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Étienne Coppée et son band d’amour se retrouvent pour chanter les grands classiques de Joe Dassin, en espérant qu’il les entende de quelque part là-haut. Il y aura du doux, des harmonies, mais aussi du rock progressif, des folies et des relectures des chansons qu’on connaît tous. On se baladera sur l’avenue, le cœur ouvert à l’inconnu et on aura envie de dire bonjour à n’importe qui.Dans une mise en scène de Myriam-Sophie Deslauriers et Flavie Melançon, ce spectacle qui appelle la nostalgie rassemble sur scène Étienne Coppée, Flavie Melançon, Raphaël Pépin-Tanguay, Bruno St-Laurent et Arthur Bourdon-Durocher.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Étienne Coppée"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
