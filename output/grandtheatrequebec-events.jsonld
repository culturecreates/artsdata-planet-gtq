  {
    "@id": "https://grandtheatre.qc.ca/programmation/les-miserables/les-miserables-2026-08-15-23-30",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/endDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-08-16T03:30:00+00:00"
      }
    ],
    "http://schema.org/image": [
      {
        "@id": "https://grandtheatre.qc.ca/uploads/original_images/JPR_MISERABLES_008_Visuel_moteur_MEV_numerique_SALLE_GT_Qc_428x600.png"
      }
    ],
    "http://schema.org/location": [
      {
        "@id": "_:g1030020"
      }
    ],
    "http://schema.org/offers": [
      {
