      }
    ],
    "http://schema.org/startDate": [
      {
        "@type": "http://schema.org/Date",
        "@value": "2026-12-04T01:00:00+00:00"
      }
    ],
    "http://schema.org/url": [
      {
        "@id": "https://www.grandtheatre.qc.ca/programmation/marie-pierre-arthur-ensemble-doux/"
      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/marie-pierre-arthur-ensemble-doux/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Marie-Pierre Arthur a envie de douceur, de proximité et de laisser toute la place aux connexions qui se créent en chantant tout près l’un de l’autre. Elle souhaite parler tout bas et mettre en valeur l’essence de ses chansons (les plus rares comme les plus connues). L’espace est partagé avec le public, si proche, qu’on en arrive presque à l’entendre respirer. Simple et complexe à la fois dans la composition des chœurs, ce spectacle fait vivre différents niveaux d'intensité et chavire à chaque chanson.Pour l’accompagner, elle a choisi d'incomparables interprètes, aussi colorés que raffinés, capables de grands contrastes : Naomie Delorimier (N Nao), Émilie Pompa (Em Pompa) et Raphaël Pépin-Tanguay (Velours Velours), son complice de tous les instants François Lafontaine (piano) et son camarade de longue date Joe Grass (guitare). Réunis sur scène, ils revisitent, réarrangent et survolent son œuvre dans l’intimité tissée serrée du cocon de l’Ensemble doux. C’est beau, essentiel et ça démontre toute la puissance de la douceur.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Ensemble doux"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
