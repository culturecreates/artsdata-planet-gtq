      }
    ],
    "http://www.w3.org/ns/prov#wasDerivedFrom": [
      {
        "@id": "https://grandtheatre.qc.ca/programmation/soiree-intime-avec-pierre-lapointe/"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "fr",
        "@value": "Pour la première fois à Québec, Pierre Lapointe présentera son spectacle Chansons démodées pour ceux qui ont le cœur abîmé dans une version intimiste présentée à la salle Octave-Crémazie. Accompagné seulement d'un piano à quatre mains, Pierre Lapointe interprétera des chansons anciennes et nouvelles et surprendra par la rigueur et la simplicité de sa proposition. Les spectateurs auront la chance de vivre une soirée unique et d’avoir une proximité exceptionnelle avec l'artiste.À propos du Duo Fortin-PoirierLe duo canadien Fortin-Poirier est reconnu pour sa force d’ensemble exceptionnelle, pour la sensibilité vive de ses deux interprètes et la complicité remarquable qui les unit. Depuis 2005, Amélie Fortin et Marie-Christine Poirier ont contribué à faire découvrir l’art du piano à quatre mains à des milliers de spectateurs par leur approche dynamique et hors normes.Une présentation du Grand Théâtre de Québec"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "fr",
        "@value": "Chansons démodées pour ceux qui ont le cœur abimé"
      }
    ],
    "http://schema.org/eventAttendanceMode": [
      {
        "@id": "http://schema.org/OfflineEventAttendanceMode"
      }
    ],
    "http://schema.org/eventStatus": [
      {
        "@id": "http://schema.org/EventScheduled"
      }
    ]
  },
